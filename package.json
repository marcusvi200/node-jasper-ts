{
  "name": "node-jasper-ts",
  "version": "3.0.1",
  "description": "JasperReports in Node.js - Compatible with NestJS",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./nest": {
      "types": "./dist/nest/index.d.ts",
      "require": "./dist/nest/index.js",
      "default": "./dist/nest/index.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "nest": [
        "dist/nest/index.d.ts"
      ],
      "*": [
        "dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "jar",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "npx tsx test.ts"
  },
  "keywords": [
    "jrxml",
    "jasper",
    "nestjs",
    "nest",
    "JasperReports",
    "pdf",
    "doc",
    "xls",
    "ts"
  ],
  "author": "Marcus Vinicius Oliveira Silva",
  "contributors": [
    {
      "name": "Agustin Moyano",
      "email": "",
      "url": "https://github.com/agmoyano"
    },
    {
      "name": "Murilo Menegasso",
      "email": "mhmsistemas@gmail.com",
      "url": "https://github.com/murilomenegasso"
    }
  ],
  "license": "ISC",
  "private": false,
  "devDependencies": {
    "@types/node": "^20.19.39",
    "typescript": "^4.7.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marcusvi200/node-jasper-ts.git"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "dotenv": "^17.4.2",
    "extend": "^3.0.2",
    "java": "^0.18.0",
    "moment": "^2.30.1",
    "xml2js": "^0.6.2"
  }
}
